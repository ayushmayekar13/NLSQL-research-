{
    "budgets": {
        "table_description": "Stores user-defined spending limits categorized by specific types of expenses.",
        "columns": [
            {
                "column_name": "budget_id",
                "data_type": "integer",
                "is_indexed": true,
                "description": "Unique identifier for each budget record."
            },
            {
                "column_name": "user_id",
                "data_type": "integer",
                "is_indexed": false,
                "description": "Identifier of the user associated with this budget."
            },
            {
                "column_name": "category",
                "data_type": "character varying",
                "is_indexed": false,
                "description": "The expense category or label for which the budget is set."
            },
            {
                "column_name": "limit_amount",
                "data_type": "numeric",
                "is_indexed": false,
                "description": "The maximum monetary amount allocated to this budget category."
            }
        ],
        "primary_keys": [
            "budget_id"
        ],
        "foreign_keys": [
            {
                "column": "user_id",
                "references_table": "users",
                "references_column": "id"
            }
        ],
        "sample_rows": [
            {
                "budget_id": 1,
                "user_id": 1,
                "category": "Entertainment",
                "limit_amount": 50.0
            },
            {
                "budget_id": 2,
                "user_id": 1,
                "category": "Music",
                "limit_amount": 30.0
            }
        ]
    },
    "reminders": {
        "table_description": "Stores a historical record of notifications or reminders sent to users regarding their subscriptions.",
        "columns": [
            {
                "column_name": "r_id",
                "data_type": "integer",
                "is_indexed": true,
                "description": "The unique primary identifier for each reminder record."
            },
            {
                "column_name": "sub_id",
                "data_type": "integer",
                "is_indexed": false,
                "description": "Reference to the subscription record associated with this reminder notification."
            },
            {
                "column_name": "user_id",
                "data_type": "integer",
                "is_indexed": false,
                "description": "Reference to the unique identifier of the user who received the reminder."
            },
            {
                "column_name": "reminder_sent_at",
                "data_type": "timestamp without time zone",
                "is_indexed": false,
                "description": "The date and time at which the reminder was dispatched to the user."
            }
        ],
        "primary_keys": [
            "r_id"
        ],
        "foreign_keys": [
            {
                "column": "sub_id",
                "references_table": "subscriptions_old",
                "references_column": "sub_id"
            },
            {
                "column": "user_id",
                "references_table": "users",
                "references_column": "id"
            }
        ],
        "sample_rows": [
